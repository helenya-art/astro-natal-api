# ── OpenAI ────────────────────────────────────────────────────────────────
# Get from platform.openai.com → API keys
OPENAI_API_KEY=sk-...

# ── Firebase Admin ────────────────────────────────────────────────────────
# Firebase Console → Project settings → Service accounts → Generate new private key
# Minify JSON: python -c "import json,sys; print(json.dumps(json.load(open('key.json'))))"
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# ── Supabase ──────────────────────────────────────────────────────────────
# Supabase Dashboard → Project settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # service_role key — never expose to clients

# ── RevenueCat ────────────────────────────────────────────────────────────
# RevenueCat Dashboard → Project → Webhooks → Signing secret
REVENUECAT_WEBHOOK_SECRET=your_signing_secret

# ── Astrology API ─────────────────────────────────────────────────────────
# astrology-api.io → Dashboard → API Keys
ASTROLOGY_API_KEY=ask_...

# ── Chat message encryption ───────────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Keep this secret — losing it makes existing chat history unreadable
CHAT_ENCRYPTION_KEY=

# ── App settings ──────────────────────────────────────────────────────────
# "production" hides /docs and enforces all required secrets
ENVIRONMENT=production
# Comma-separated origins allowed for CORS (required in production)
ALLOWED_ORIGINS=https://your-api-domain.com
# Max chart creations per user per hour
CHART_RATE_LIMIT=5

# ── Image style references ────────────────────────────────────────────────
STYLE_REFERENCE_URL_FEMALE=
STYLE_REFERENCE_URL_MALE=

# ── Testers: comma-separated Firebase UIDs, leave empty in production ─────
# TEST_PREMIUM_USERS=uid1,uid2,uid3
